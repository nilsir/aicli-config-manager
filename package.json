{
  "name": "aicli-config-manager",
  "version": "1.0.0",
  "description": "Local web dashboard to view and manage AI CLI tool configurations",
  "keywords": ["ai", "cli", "config", "claude", "copilot", "gemini", "codex", "opencode", "mcp"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nilsir/aicli-config-manager"
  },
  "bin": {
    "aicli-config-manager": "./bin/start.js"
  },
  "files": [
    "bin/",
    "server/",
    "web/dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"bun run server/index.ts\" \"bun run --cwd web dev\"",
    "build": "bun run --cwd web build",
    "start": "bun run server/index.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "smol-toml": "^1.3.1"
  }
}
